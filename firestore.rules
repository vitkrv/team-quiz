rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId}/public/data/packs/{packId} {
      allow read: if isGoogleUser()
        && (
          resource.data.ownerId == request.auth.uid
          || resource.data.isPublic == true
        );
      allow create: if isGoogleUser()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isGoogleUser()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isGoogleUser()
        && resource.data.ownerId == request.auth.uid;
    }

    match /artifacts/{appId}/public/data/rooms/{roomCode} {
      allow read: if isGoogleUser();
      allow create: if isGoogleUser()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.packId is string
        && canHostPack(appId, request.resource.data.packId, request.auth.uid);
      allow update: if isGoogleUser()
        && (
          roomParticipantOrHost(resource.data, request.auth.uid)
          || canJoinLobby(resource.data, request.resource.data, request.auth.uid)
        );
      allow delete: if false;
    }

    match /artifacts/{appId}/users/{userId} {
      allow read: if isGoogleUser()
        && request.auth.uid == userId;
      allow create: if isGoogleUser()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['language', 'updatedAt'])
        && request.resource.data.language in ['en', 'uk'];
      allow update: if isGoogleUser()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['language', 'updatedAt'])
        && request.resource.data.language in ['en', 'uk'];
      allow delete: if false;
    }

    match /artifacts/{appId}/users/{userId}/clockSync/{syncId} {
      allow read: if isGoogleUser()
        && request.auth.uid == userId;
      allow create, update: if isGoogleUser()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['serverReceivedAt', 'clientSentAt', 'sampleId'])
        && request.resource.data.serverReceivedAt == request.time
        && (request.resource.data.clientSentAt is int || request.resource.data.clientSentAt is float)
        && request.resource.data.sampleId is string;
      allow delete: if false;
    }

    function roomParticipantOrHost(room, uid) {
      return room.hostId == uid || uid in room.players;
    }

    function canJoinLobby(before, after, uid) {
      return before.status == 'lobby'
        && after.status == before.status
        && !(uid in before.players)
        && uid in after.players
        && after.players[uid].isHost == false
        && after.diff(before).changedKeys().hasOnly(['players']);
    }

    function canHostPack(appId, packId, uid) {
      let pack = get(/databases/$(database)/documents/artifacts/$(appId)/public/data/packs/$(packId)).data;
      return pack.ownerId == uid || pack.isPublic == true;
    }

    function isGoogleUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }
  }
}
